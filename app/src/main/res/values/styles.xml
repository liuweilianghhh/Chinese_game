<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ShapeAppearanceOverlayChineseGameRoundedXL">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">22dp</item>
    </style>

    <style name="Widget.ChineseGame.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:minHeight">54dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.015</item>
        <item name="backgroundTint">@color/duo_green</item>
        <item name="rippleColor">@color/duo_green_soft</item>
        <item name="elevation">4dp</item>
    </style>

    <style name="Widget.ChineseGame.Button.Secondary" parent="Widget.ChineseGame.Button">
        <item name="backgroundTint">@color/duo_blue</item>
        <item name="rippleColor">@color/duo_blue_soft</item>
    </style>

    <style name="Widget.ChineseGame.Button.Danger" parent="Widget.ChineseGame.Button">
        <item name="backgroundTint">@color/duo_red_dark</item>
    </style>

    <style name="Widget.ChineseGame.Button.Textured" parent="Widget.ChineseGame.Button.Outlined">
        <item name="strokeWidth">0dp</item>
        <item name="android:background">@drawable/bg_panel_soft</item>
        <item name="android:textColor">@color/duo_text_dark</item>
    </style>

    <style name="Widget.ChineseGame.Button.Compact" parent="Widget.ChineseGame.Button">
        <item name="android:minHeight">46dp</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="Widget.ChineseGame.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:minHeight">54dp</item>
        <item name="android:textColor">@color/duo_text_dark</item>
        <item name="strokeColor">@color/duo_green_dark</item>
        <item name="strokeWidth">2dp</item>
        <item name="rippleColor">@color/duo_green_soft</item>
        <item name="android:letterSpacing">0.015</item>
    </style>

    <style name="Widget.ChineseGame.Toolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@drawable/bg_toolbar_primary</item>
        <item name="titleTextColor">@android:color/white</item>
        <item name="subtitleTextColor">#CCFFFFFF</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Widget.ChineseGame.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">22dp</item>
        <item name="cardElevation">5dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/duo_card_stroke</item>
        <item name="cardBackgroundColor">@color/duo_card_bg</item>
    </style>

    <style name="Widget.ChineseGame.Card.Flat" parent="Widget.ChineseGame.Card">
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/duo_divider</item>
    </style>

    <style name="Widget.ChineseGame.Text.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/duo_text_muted</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="Widget.ChineseGame.Text.SectionTitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">@color/duo_text_dark</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.ChineseGame.Text.Chip" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/duo_chip_text</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="Widget.ChineseGame.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundMode">outline</item>
        <item name="boxCornerRadiusTopStart">18dp</item>
        <item name="boxCornerRadiusTopEnd">18dp</item>
        <item name="boxCornerRadiusBottomStart">18dp</item>
        <item name="boxCornerRadiusBottomEnd">18dp</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxStrokeColor">@color/duo_green_dark</item>
        <item name="hintTextColor">@color/duo_text_muted</item>
        <item name="counterTextColor">@color/duo_text_muted</item>
        <item name="errorTextColor">@color/duo_red_dark</item>
    </style>
</resources>

