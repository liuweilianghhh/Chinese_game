<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_secondary"
    android:orientation="vertical"
    tools:context=".GameRecordsActivity">

    <com.google.android.material.appbar.MaterialToolbar
        style="@style/Widget.ChineseGame.Toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title="Game Records"
        app:titleCentered="true"
        app:titleTextColor="@android:color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:gravity="center"
                android:text="Switch game mode and time range to inspect your accuracy trend"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
                android:textColor="@color/duo_text_muted" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.ChineseGame.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:text="Game Mode"
                        android:textAppearance="@style/Widget.ChineseGame.Text.SectionTitle" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/toggle_game_type"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:selectionRequired="true"
                        app:singleSelection="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_filter_character_matching"
                            style="@style/Widget.ChineseGame.Button.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Matching" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_filter_pronunciation"
                            style="@style/Widget.ChineseGame.Button.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Pronunciation" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_filter_word_puzzle"
                            style="@style/Widget.ChineseGame.Button.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Word Puzzle" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="10dp"
                        android:text="Time Range"
                        android:textAppearance="@style/Widget.ChineseGame.Text.SectionTitle" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/toggle_time_range"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:selectionRequired="true"
                        app:singleSelection="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_range_7"
                            style="@style/Widget.ChineseGame.Button.Outlined"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="7D" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_range_30"
                            style="@style/Widget.ChineseGame.Button.Outlined"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="30D" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_range_90"
                            style="@style/Widget.ChineseGame.Button.Outlined"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="90D" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_range_all"
                            style="@style/Widget.ChineseGame.Button.Outlined"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="All" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.ChineseGame.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_records_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
                        android:textColor="@color/duo_text_dark"
                        tools:text="Character Matching · 6 records · Average accuracy 78% · Best score 90/100" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.ChineseGame.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="Accuracy Trend"
                        android:textAppearance="@style/Widget.ChineseGame.Text.SectionTitle" />

                    <com.example.chinese_game.view.AccuracyChartView
                        android:id="@+id/accuracy_chart_view"
                        android:layout_width="match_parent"
                        android:layout_height="240dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.ChineseGame.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_records_section_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="Recent Records"
                        android:textAppearance="@style/Widget.ChineseGame.Text.SectionTitle" />

                    <LinearLayout
                        android:id="@+id/records_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_back_records"
        style="@style/Widget.ChineseGame.Button.Outlined"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="Back to Game Selection" />
</LinearLayout>
