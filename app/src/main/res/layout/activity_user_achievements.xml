<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_secondary"
    android:orientation="vertical"
    tools:context=".UserAchievementsActivity">

    <com.google.android.material.appbar.MaterialToolbar
        style="@style/Widget.ChineseGame.Toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title="My Achievements"
        app:titleCentered="true"
        app:titleTextColor="@android:color/white" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:alpha="0.75"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:text="Track every badge and see the progress still needed"
        android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
        android:textColor="@color/duo_text_muted" />

    <TextView
        android:id="@+id/tv_achievement_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingHorizontal="20dp"
        android:paddingBottom="6dp"
        android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle2"
        android:textColor="@color/duo_text_dark"
        android:textStyle="bold"
        tools:text="Unlocked 2 / 5  •  Reward Points 150" />

    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="4dp"
        android:contentDescription="Cat Mascot"
        android:src="@drawable/ui_icon_mascot" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_panel_soft"
        android:layout_marginHorizontal="14dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="8dp"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:id="@+id/achievements_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_back"
        style="@style/Widget.ChineseGame.Button.Outlined"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="Back to Game Selection" />
</LinearLayout>

