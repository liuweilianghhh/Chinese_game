<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_panel"
    android:minWidth="280dp"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="8dp"
        android:text="Select Difficulty"
        android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
        android:textColor="@color/duo_text_dark"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:gravity="center"
        android:text="All 10 questions in this game will be of the selected difficulty."
        android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
        android:textColor="@color/duo_text_muted" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_difficulty_easy"
        style="@style/Widget.ChineseGame.Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="Easy" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_difficulty_medium"
        style="@style/Widget.ChineseGame.Button.Secondary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="Medium" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_difficulty_hard"
        style="@style/Widget.ChineseGame.Button.Danger"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="Hard" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_difficulty_cancel"
        style="@style/Widget.ChineseGame.Button.Outlined"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cancel" />
</LinearLayout>

