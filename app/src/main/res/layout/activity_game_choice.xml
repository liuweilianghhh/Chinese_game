<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_game_choice_menu"
    android:orientation="vertical"
    tools:context=".game_choice">

    <com.google.android.material.appbar.MaterialToolbar
        style="@style/Widget.ChineseGame.Toolbar"
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title="Choose Game"
        app:titleCentered="true"
        app:titleTextColor="@android:color/white">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/menu_dropdown"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_chip_info"
            android:clickable="true"
            android:contentDescription="Menu"
            android:focusable="true"
            android:padding="6dp"
            android:src="@drawable/ui_icon_menu_dots"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.SmallComponent" />
    </com.google.android.material.appbar.MaterialToolbar>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/game_choice_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <ImageView
                android:id="@+id/iv_choice_mascot"
                android:layout_width="84dp"
                android:layout_height="84dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:contentDescription="Mascot"
                android:src="@drawable/ui_icon_mascot" />

            <TextView
                android:id="@+id/tv_choice_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:gravity="center"
                android:text="Pick one challenge and start your streak"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
                android:textColor="@color/duo_text_muted" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.ChineseGame.Card"
                android:id="@+id/card_game_modes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_character_matching"
                        style="@style/Widget.ChineseGame.Button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="Character Matching" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_pronunciation_quiz"
                        style="@style/Widget.ChineseGame.Button.Secondary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="Pronunciation Quiz" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_word_puzzle"
                        style="@style/Widget.ChineseGame.Button.Compact"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Word Puzzle" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
