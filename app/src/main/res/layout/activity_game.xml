<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_game_surface"
    android:fillViewport="true"
    tools:context=".GameActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="24dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tv_game_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:textColor="@color/duo_text_dark"
                android:textSize="22sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_music_settings"
                style="@style/Widget.ChineseGame.Button.Outlined"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|center_vertical"
                android:minWidth="0dp"
                android:text="Music"
                android:textAllCaps="false"
                app:icon="@drawable/ic_music_note_24"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="@color/duo_text_dark" />
        </FrameLayout>

        <ImageView
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="12dp"
            android:contentDescription="Cat Mascot"
            android:src="@drawable/ui_icon_mascot" />

        <TextView
            android:id="@+id/tv_feedback_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:drawablePadding="8dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:textColor="@color/duo_text_dark"
            android:textSize="14sp"
            android:visibility="gone" />

        <!-- 闈炲瓧褰㈠尮閰嶆椂鏄剧ず -->
        <TextView
            android:id="@+id/tv_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="This game is coming soon..."
            android:textSize="16sp"
            android:textColor="@color/duo_text_muted"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            android:visibility="gone" />

        <!-- 瀛楀舰鍖归厤娓告垙鍖哄煙 -->
        <LinearLayout
            android:id="@+id/panel_character_matching"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_panel_soft"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 / 10"
                android:textSize="14sp"
                android:textColor="@color/duo_text_muted"
                android:layout_marginBottom="18dp" />

            <TextView
                android:id="@+id/tv_pinyin_question"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="28sp"
                android:textColor="@color/duo_text_dark"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_chip_info"
                android:padding="24dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tv_question_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/duo_text_muted"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_opt1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp"
                    android:onClick="onOptionClick" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_opt2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp"
                    android:onClick="onOptionClick" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_opt3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp"
                    android:onClick="onOptionClick" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_opt4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp"
                    android:onClick="onOptionClick" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="18sp"
                android:textColor="@color/duo_text_dark"
                android:gravity="start"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_back_to_menu"
                style="@style/Widget.ChineseGame.Button.Outlined"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Back to Game Selection"
                android:textSize="16sp"
                android:padding="12dp"
                android:layout_marginTop="16dp" />
        </LinearLayout>

        <!-- 鍙戦煶娴嬮獙娓告垙鍖哄煙 -->
        <LinearLayout
            android:id="@+id/panel_word_puzzle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_panel_soft"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_word_puzzle_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 / 10"
                android:textSize="14sp"
                android:textColor="@color/duo_text_muted"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tv_word_puzzle_context"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textColor="@color/duo_text_dark"
                android:textStyle="bold"
                android:gravity="center"
                android:padding="12dp"
                android:background="@drawable/bg_chip_info"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_word_puzzle_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/duo_text_muted"
                android:gravity="center"
                android:layout_marginBottom="14dp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/layout_word_puzzle_slots"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="2dp" />
            </HorizontalScrollView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Drag 5 blocks to slots"
                android:textSize="13sp"
                android:textColor="@color/duo_text_muted"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/layout_word_puzzle_source"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="2dp" />
            </HorizontalScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_word_puzzle_reset"
                    style="@style/Widget.ChineseGame.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Reset"
                    android:textSize="16sp"
                    android:layout_marginEnd="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_word_puzzle_submit"
                    style="@style/Widget.ChineseGame.Button.Secondary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Submit"
                    android:textSize="16sp"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_word_puzzle_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="16sp"
                android:textColor="@color/duo_text_dark"
                android:gravity="start"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_word_puzzle_back"
                style="@style/Widget.ChineseGame.Button.Outlined"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Back to Game Selection"
                android:textSize="16sp"
                android:padding="12dp"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/panel_pronunciation_quiz"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_panel_soft"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_pronunciation_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 / 10"
                android:textSize="14sp"
                android:textColor="@color/duo_text_muted"
                android:layout_marginBottom="24dp" />

            <TextView
                android:id="@+id/tv_pronunciation_instruction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Read the following word:"
                android:textSize="16sp"
                android:textColor="@color/duo_text_muted"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tv_pronunciation_word"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="48sp"
                android:textColor="@color/duo_text_dark"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_chip_info"
                android:padding="24dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_pronunciation_pinyin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="24sp"
                android:textColor="@color/duo_red_dark"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tv_question_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/duo_text_muted"
                android:maxLines="2"
                android:ellipsize="end"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <TextView
                android:id="@+id/tv_recognition_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hold the mic to speak"
                android:textSize="14sp"
                android:textColor="@color/duo_text_muted"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <!-- 澹版尝鍔ㄦ€佸彲瑙嗗寲 -->
            <com.example.chinese_game.view.VoiceWaveView
                android:id="@+id/voice_wave_view"
                android:layout_width="200dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:layout_marginBottom="16dp" />

            <!-- 闀挎寜楹﹀厠椋庢寜閽?-->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_start_recording"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:background="@drawable/ui_bg_mic_idle"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text=""
                android:padding="0dp"
                android:layout_marginBottom="12dp"
                app:backgroundTint="@null"
                app:cornerRadius="40dp"
                app:icon="@drawable/ui_icon_mic_skeu"
                app:iconGravity="textTop"
                app:iconPadding="0dp"
                app:iconSize="36dp"
                app:iconTint="@null" />

            <!-- 褰撳墠棰樼洰寰楀垎 -->
            <TextView
                android:id="@+id/tv_current_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textColor="@color/duo_blue"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="12dp"
                android:visibility="gone" />

            <!-- Next 鎸夐挳 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_next_question"
                style="@style/Widget.ChineseGame.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Next"
                android:textSize="18sp"
                android:padding="14dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone" />

            <!-- 鏈€缁堟€诲垎 -->
            <TextView
                android:id="@+id/tv_pronunciation_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="16sp"
                android:textColor="@color/duo_text_dark"
                android:gravity="start"
                android:visibility="gone" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back_to_menu_placeholder"
            style="@style/Widget.ChineseGame.Button.Outlined"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Back to Game Selection"
            android:textSize="16sp"
            android:padding="12dp"
            android:layout_marginTop="16dp" />
    </LinearLayout>
</ScrollView>



